<Window x:Class="PNCA_BIM_Suite_Library.Views.CreateViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views"
        Title="Create Views"         
        Height="500" 
        Width="500"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
    <Border Background="White" BorderBrush="#3A3A3A" 
        BorderThickness="1" VerticalAlignment="Center" Padding="0,0,0,0" Height="500">
        <DockPanel LastChildFill="True">
            <Border Background="#2B2B2B" Height="32" DockPanel.Dock="Top" 
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <local:TitleBar
                    TitleBarText="Create Views"
                    Minimize_Click="{Binding Minimize_Click}"
                    Close_Click="{Binding Close_Click}"
                                IconPath="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/ViewGEN-Titlebar.png"
                    />

            </Border>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>




                <!-- Main Content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel -->
                    <GroupBox Grid.Column="0" Header="Available Levels" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- ListBox for Available Levels -->
                            <ListBox x:Name="AvailableLevelsListBox" 
                             Grid.Row="0"
                             SelectionMode="Multiple"
                             Margin="5"/>

                            <!-- Check buttons -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="5">
                                <Button x:Name="CheckAllButton" Content="Check All" 
                                Width="80" Height="20" Margin="0,0,10,0" 
                                Click="CheckAllButton_Click"
                                FontSize="12" 
                                Foreground="White" Background="#FF4F4F50"/>
                                <Button x:Name="CheckNoneButton" Content="Check None" 
                                Width="80" Height="20" Click="CheckNoneButton_Click"
                                FontSize="12" 
                                Foreground="White" Background="#FF4F4F50"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Right Panel -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">

                        <!-- Type Selection -->
                        <GroupBox Header="View Types" Margin="0,0,0,15">
                            <ComboBox x:Name="TypeComboBox" Height="25" Margin="5"/>
                        </GroupBox>

                        <!-- Discipline Selection -->
                        <GroupBox Header="Discipline" Margin="0,0,0,15">
                            <ComboBox x:Name="DisciplineComboBox" Height="25" Margin="5"/>
                        </GroupBox>                        

                        <!-- Sub Discipline Selection -->
                        <GroupBox Header="Sub Discipline" Margin="0,0,0,15">
                            <TextBox x:Name="SubDisciplineTextBox" Height="25" Margin="5"/>
                        </GroupBox>

                    </StackPanel>
                </Grid>

                <!-- Bottom Panel -->
                <Grid Grid.Row="2" Margin="0,10,0,0" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="CreateButton" Content="Create" Width="80" 
                        Height="25" Margin="0,10,10,0" 
                        FontSize="14" 
                        Foreground="White" Background="#FF4F4F50"
                        Click="Create_Click"/>
                        <Button x:Name="CancelButton" Content="Cancel" Width="80" 
                        Height="25" Margin="0,10,10,0"
                        FontSize="14" 
                        Foreground="White" Background="#FF4F4F50"
                        Click="Cancel_Click"/>
                    </StackPanel>

                    <!-- PWC Logo Button -->
                    <Image Grid.Column="1"
                           Source="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/PNC Logo.png"
                    Width="100"
                    Height="50"
                    Margin="0,10,0,0"
                    Stretch="Uniform"/>

                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>