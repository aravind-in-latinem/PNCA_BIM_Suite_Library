<Window x:Class="PNCA_BIM_Suite_Library.Views.SheetCreatorExcelInput"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views"
        Height="425"
        Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">
    <Border Background="White"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            VerticalAlignment="Center"
            Padding="0,0,0,0"
            Height="425">
        <DockPanel LastChildFill="True">
            <Border Background="#2B2B2B"
                    Height="32"
                    DockPanel.Dock="Top"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <local:PNCATitleBar Title="SheetGEN : Excel Input"
                                    TitleIcon="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/SheetCreatorExcelInput-Titlebar.ico" />
            </Border>

            <Grid Margin="10">
                <StackPanel>

                    <GroupBox Header="Load Excel File:"
                              Margin="0,0,0,10"
                              FontSize="14">
                        <Button Content="Browse"
                                Margin="10,5,0,5"
                                FontSize="14"
                                Foreground="White"
                                Background="#FF4F4F50"
                                FontStyle="Italic"
                                Width="75"
                                HorizontalAlignment="Left"
                                Click="BrowseExcel_Click" />
                    </GroupBox>

                    <GroupBox Header="Select Sheet Number Column:"
                              Margin="0,0,0,10"
                              FontSize="14">
                        <ComboBox x:Name="SheetNumberColumnDropDown"
                                  Width="250"
                                  Margin="0,5,0,5" />
                    </GroupBox>

                    <GroupBox Header="Select Sheet Name Column:"
                              Margin="0,0,0,10"
                              FontSize="14">
                        <ComboBox x:Name="SheetNameColumnDropDown"
                                  Width="250"
                                  Margin="0,5,0,5" />
                    </GroupBox>

                    <GroupBox Header="Select Title Block:"
                              Margin="0,10,0,10"
                              FontSize="14">
                        <ComboBox x:Name="ExcelTitleBlockDropDown"
                                  Width="250"
                                  Margin="0,5,0,5" />
                    </GroupBox>

                    <StackPanel Orientation="Horizontal"
                                Margin="10,30,0,10">
                        <Button Content="Create"
                                Width="100"
                                Height="30"
                                Click="ExcelCreateButton_Click"
                                FontSize="14"
                                Foreground="White"
                                Background="#FF4F4F50" />
                        <Button Content="Cancel"
                                Width="100"
                                Height="30"
                                Margin="10,0,0,0"
                                Click="ExcelCancelButton_Click"
                                Foreground="White"
                                FontSize="14"
                                Background="#FF4F4F50" />
                    </StackPanel>

                    <Image Source="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/PNC Logo.png"
                           Height="50"
                           Width="50"
                           HorizontalAlignment="Right"
                           Margin="0,-50,5,0"
                           VerticalAlignment="Top" />

                </StackPanel>

            </Grid>
        </DockPanel>
    </Border>
</Window>
