<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="ActionButtonStyle" TargetType="Button">
        
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="#4F4F50"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!-- Hover effect (optional) -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#5F5F60"/>
            </Trigger>

            <!-- Disabled state -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#818285"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="TabButtonStyle"
           TargetType="Button">

        <!-- Base appearance -->
        <Setter Property="FontSize"
                Value="13" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="Background"
                Value="#5A5A5A" />
        <Setter Property="BorderBrush"
                Value="#7A7A7A" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Padding"
                Value="16,6" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="MinWidth"
                Value="70" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8,8,0,0">

                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>

                    <!-- Visual states -->
                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver"
                                 Value="True">
                            <Setter Property="Background"
                                    Value="#6A6A6A" />
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter Property="Background"
                                    Value="#4A4A4A" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Opacity"
                                    Value="0.5" />
                            <Setter Property="Cursor"
                                    Value="Arrow" />
                            <Setter Property="Background"
                                    Value="#818285" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabRadioStyle" TargetType="RadioButton">
        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border"
                        Background="#818285"
                        CornerRadius="4"
                        BorderBrush="Black"
                        BorderThickness="1"
                        Padding="5">

                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#4F4F50"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="#1A1A1A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#6B6B6E"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="Background" Value="#AAAAAA"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TabToggleButtonStyle"
           TargetType="ToggleButton">

        <!-- Base = INACTIVE tab -->
        <Setter Property="FontSize"
                Value="13" />
        <Setter Property="FontWeight"
                Value="SemiBold" />
        <Setter Property="Foreground"
                Value="White" />
        <Setter Property="Background"
                Value="#6A6A6A" />
        <!-- lighter -->
        <Setter Property="BorderBrush"
                Value="#8A8A8A" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Padding"
                Value="16,6" />
        <Setter Property="Cursor"
                Value="Hand" />
        <Setter Property="MinWidth"
                Value="70" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8,8,0,0">

                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- ACTIVE TAB -->
                        <Trigger Property="IsChecked"
                                 Value="True">
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="#4A4A4A" />
                            <Setter TargetName="Border"
                                    Property="BorderBrush"
                                    Value="White" />
                        </Trigger>

                        <!-- Hover (inactive only) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver"
                                           Value="True" />
                                <Condition Property="IsChecked"
                                           Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="#707070" />
                        </MultiTrigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed"
                                 Value="True">
                            <Setter TargetName="Border"
                                    Property="Background"
                                    Value="#3A3A3A" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled"
                                 Value="False">
                            <Setter Property="Opacity"
                                    Value="0.5" />
                            <Setter Property="Cursor"
                                    Value="Arrow" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

    <Style x:Key="BoldGroupBoxHeaderStyle"
           TargetType="GroupBox">
        <Setter Property="FontSize"
                Value="13" />
        <Setter Property="FontWeight"
                Value="Normal" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Padding="6,2"
                                Background="Transparent">
                            <TextBlock Text="{TemplateBinding Header}"
                                       FontWeight="Bold"
                                       FontSize="{TemplateBinding FontSize}" />
                        </Border>

                        <!-- Content -->
                        <Border Grid.Row="1"
                                Margin="0,4,0,0"
                                BorderBrush="White"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AnimalToggleStyle"
           TargetType="ToggleButton">
        <Setter Property="Width"
                Value="80" />
        <Setter Property="Height"
                Value="25" />
        <Setter Property="Content">
            <Setter.Value>
                <Image Width="80"
                       Height="23"
                       VerticalAlignment="Center"
                       Source="pack://application:,,,/PNCA_SheetExporter;component/Resources/Quick_Mode.png" />
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsChecked"
                     Value="True">
                <Setter Property="Content">
                    <Setter.Value>
                        <Image Width="80"
                               Height="23"
                               VerticalAlignment="Center"
                               Source="pack://application:,,,/PNCA_SheetExporter;component/Resources/Heavy_Mode.png" />
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>