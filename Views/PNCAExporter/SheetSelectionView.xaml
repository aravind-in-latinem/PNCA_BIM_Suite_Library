<UserControl x:Class="PNCA_BIM_Suite_Library.Views.PNCAExporter.SheetSelectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views.PNCAExporter"
             mc:Ignorable="d"
             d:DesignHeight="356"
             d:DesignWidth="860">
    <UserControl.Resources>
        <!-- CollectionViewSource for better performance and refresh control -->
        <CollectionViewSource x:Key="SheetsViewSource"
                              Source="{Binding FilteredSheets}">
            <!-- Optional: Add sorting/filtering -->
            <!--
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="SheetNumber" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
            -->
        </CollectionViewSource>
    </UserControl.Resources>

    <Grid>
        

        <DataGrid ItemsSource="{Binding Source={StaticResource SheetsViewSource}}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Extended"
                  IsReadOnly="False"
                  HeadersVisibility="Column"
                  BorderBrush="Gray"
                  GridLinesVisibility="None"
                  RowHeaderWidth="0"
                  EnableRowVirtualization="True"
                  EnableColumnVirtualization="False">

            <DataGrid.Columns>
                <!-- Checkbox Column -->
                <DataGridTemplateColumn Width="25">
                    <DataGridTemplateColumn.Header>
                        <CheckBox IsChecked="{Binding DataContext.HeaderCheckState, 
                                     Mode=TwoWay,
                                     RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                  Command="{Binding DataContext.ToggleSelectAllCommand,
                                     RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                  CommandParameter="{Binding IsChecked,
                                     RelativeSource={RelativeSource Self}}" />
                    </DataGridTemplateColumn.Header>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, 
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Data Columns -->
                <DataGridTextColumn Header="Sheet No."
                                    Binding="{Binding SheetNumber}"
                                    Width="60" />
                <DataGridTextColumn Header="Sheet Name"
                                    Binding="{Binding Name}"
                                    Width="Auto"
                                    MinWidth="150"/>
                <DataGridTextColumn Header="Rev"
                                    Binding="{Binding RevisionNo}"
                                    Width="50" />
                <DataGridTextColumn Header="Size"
                                    Binding="{Binding Size}"
                                    Width="115" />

                <DataGridTemplateColumn Width="Auto"
                                        MinWidth="150">
                    <!-- HEADER -->
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="File Name"
                                           Margin="0,0,5,0" />

                                <Button Content="..."
                                        Height="16"
                                        Command="{Binding Path=DataContext.CustomizeFileName,
                                  RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>

                    <!-- CELL -->
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FileName}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>
