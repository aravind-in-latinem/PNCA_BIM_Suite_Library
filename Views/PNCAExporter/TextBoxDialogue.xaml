<Window x:Class="PNCA_BIM_Suite_Library.Views.PNCAExporter.TextBoxDialogue"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views"
             mc:Ignorable="d" 
             WindowStyle="None"
             AllowsTransparency="True"
             Height="200" Width="500">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PNCA_BIM_Suite_Library;component/Views/ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Background="White">
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <local:PNCATitleBar Grid.ColumnSpan="2"
                            Title="{Binding TitleText, Mode=TwoWay}"
                            />
        <TextBlock Grid.Row="1"
                   Text="{Binding Message, Mode=TwoWay}"
                   Margin="0,-2,15,0"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   FontSize="14"
                   TextAlignment="Right"
                   Height="Auto" />
        <TextBox Grid.Row="1"
                 Grid.Column="1"
                 Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Height="23"
                 Margin="15,0,20,0"
                 VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal">
            <Button Grid.Row="2"
                    Content="Ok"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="Ok_Click"
                    Height="30"
                    Width="90"
                    Margin="15,0,15,0" />
            <Button Grid.Row="2"
                    Grid.Column="1"
                    Content="Cancel"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="Cancel_Click"
                    Height="30"
                    Width="90"
                    HorizontalAlignment="Left"
                    Margin="15,0,0,0" />

        </StackPanel>
        

    </Grid>
</Window>
