<Window x:Class="PNCA_BIM_Suite_Library.Views.PNCAExporter.CustomNamingRuleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views"
        xmlns:localI="clr-namespace:PNCA_BIM_Suite_Library.Views.PNCAExporter"
        xmlns:pncaExporter="clr-namespace:PNCA_BIM_Suite_Library.ViewModel.PNCAExporter"
        mc:Ignorable="d"
        AllowsTransparency="True"
        WindowStyle="None"
        Height="482"
        Width="800">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PNCA_BIM_Suite_Library;component/Views/ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border BorderBrush="Black"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <local:PNCATitleBar Title="Custom File Name Settings" />
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal">
                <TextBlock Text="Preview:"
                           FontSize="14"
                           Margin="10,0,5,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Row="1"
                           Text="{Binding PreviewText}"
                           Margin="0,0,10,0"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Height="Auto" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="55" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <ListBox ItemsSource="{Binding AvailableParameters}"
                             SelectionMode="Extended"
                             Height="300"
                             Margin="10"
                             DisplayMemberPath="Name"
                             pncaExporter:ListBoxSelectedItemsBehavior.SelectedItems="{Binding SelectedLHSParameters}" />
                    <TextBlock Text="Custom Keyword:"
                               FontSize="14"
                               Margin="10,0,10,5"
                               HorizontalAlignment="Left" />
                    <TextBox Text="{Binding CustomKeyword, Mode=TwoWay}"
                             Height="30"
                             Margin="10"
                             FontSize="14"
                             TextAlignment="Left"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center" />

                </StackPanel>
                <StackPanel Grid.Column="1">
                    <Button Content="»"
                            Command="{Binding AddParameterCommand}"
                            Width="50"
                            Height="30"
                            Margin="0,100,0,10"
                            FontSize="17" />
                    <Button Content="«"
                            Command="{Binding RemoveParameterCommand}"
                            Width="50"
                            Height="30"
                            FontSize="17" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <ListBox ItemsSource="{Binding SelectedParameters}"
                             SelectionMode="Extended"
                             Height="300"
                             Margin="10"
                             DisplayMemberPath="Name"
                             pncaExporter:ListBoxSelectedItemsBehavior.SelectedItems="{Binding SelectedRHSParameters}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Seperator:"
                                   FontSize="14"
                                   Margin="10,0,10,5"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center" />
                        <TextBox Text="{Binding Seperator, Mode=TwoWay}"
                                 Width="50"
                                 Height="30" 
                                 />
                        <Button Content="▲"
                                Width="32"
                                Command="{Binding MoveToFirstCommand}"
                                Margin="15,0,0,0" />
                        <Button Content="⋀"
                                Width="32"
                                Command="{Binding MoveUpCommand}"
                                Margin="15,0,0,0" />                        
                        
                        <Button Content="∨"
                                Width="32"
                                Command="{Binding MoveDownCommand}"
                                Margin="15,0,0,0" />
                        <Button Content="▼"
                                Width="32"
                                Command="{Binding MoveToLastCommand}"
                                Margin="15,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Height="65">
                        <Button Content="Ok"
                                Click="Ok_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="90"
                                Height="30"
                                Margin="10,0,10,0" />
                        <Button Content="Clear"
                                Command="{Binding ClearCommand}"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="90"
                                Height="30"
                                Margin="0,0,10,0" />
                        <Button Content="Cancel"
                                Click="Cancel_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Width="90"
                                Height="30"
                                Margin="0,0,10,0" />
                    </StackPanel>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</Window>
