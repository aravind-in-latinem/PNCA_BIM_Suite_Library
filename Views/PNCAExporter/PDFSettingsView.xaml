<UserControl x:Class="PNCA_BIM_Suite_Library.Views.PNCAExporter.PDFSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views.PNCAExporter"
             xmlns:vm="clr-namespace:PNCA_BIM_Suite_Library.Services"
             mc:Ignorable="d"
             d:DesignHeight="348"
             d:DesignWidth="750">
    <UserControl.Resources>
        <ResourceDictionary>
            <vm:EnumToBoolConverter x:Key="EnumToBoolConverter" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PNCA_BIM_Suite_Library;component/Views/ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="100" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <GroupBox Header="PDF Settings"
                  Style="{StaticResource BoldGroupBoxHeaderStyle}"
                  BorderThickness="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>
                <GroupBox Header="Printer">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Printer Name:"
                                   ToolTip="Switch to Heavy Mode to Activate"
                                   FontWeight="DemiBold"
                                   Margin="4,7,0,0"
                                   VerticalAlignment="Center" />
                        <ComboBox Width="200"
                                  ItemsSource="{Binding PrinterNames}"
                                  SelectedItem="{Binding SelectedPrinterName}"
                                  IsEnabled="{Binding DataContext.IsHeavyModeChecked, RelativeSource={RelativeSource AncestorType=Window}}"
                                  Margin="5,5,0,5"
                                  Height="23" />
                    </StackPanel>

                </GroupBox>
                <GroupBox Header="Export Settings"
                          Grid.Column="1">

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal">
                        <TextBlock Text="PDF Export Setting:"
                                   FontWeight="DemiBold"
                                   VerticalAlignment="Center"
                                   Margin="4,7,0,0" />
                        <ComboBox Width="200"
                                  ItemsSource="{Binding PDFExportSettingsCollection}"
                                  SelectedItem="{Binding SelectedPDFExportSettingItem}"
                                  DisplayMemberPath="Name"
                                  Margin="10,5,0,0"
                                  Height="23" />

                        <Button Content="..."
                                Width="30"
                                Margin="10,5,0,0"
                                Height="23"
                                Click="ContextMenu_Click">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Save"
                                              Command="{Binding SavePDFOption}" />

                                    <MenuItem Header="Save As…"
                                              Command="{Binding SaveAsPDFOption}" />

                                    <MenuItem Header="Rename…"
                                              Command="{Binding RenamePDFOption}" />

                                    <Separator />

                                    <MenuItem Header="Delete"
                                              Command="{Binding DeletePDFOption}" />
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </GroupBox>

        <StackPanel Orientation="Vertical"
                    Grid.Row="1">
            <StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="486" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Orientation="Horizontal">
                            <GroupBox Header="Size">
                                <Grid Margin="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Sheet Size -->
                                    <TextBlock Text="Sheet Size:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               Grid.Row="0"
                                               Grid.Column="0" />

                                    <ComboBox Width="150"
                                              ItemsSource="{Binding PaperFormatOptions}"
                                              SelectedItem="{Binding SelectedPaperFormatOption}"
                                              Grid.Row="0"
                                              Grid.Column="1" />

                                    <!-- Zoom -->
                                    <TextBlock Text="Zoom:"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,-20,8,0"
                                               Grid.Row="1"
                                               Grid.Column="0" />

                                    <StackPanel Grid.Row="1"
                                                Grid.Column="1"
                                                Margin="0,5,0,0">

                                        <RadioButton Content="Fit to Page"
                                                     GroupName="ZoomOptions"
                                                     IsChecked="{Binding ZoomType,
                                                             Converter={StaticResource EnumToBoolConverter},
                                                             ConverterParameter=FitToPage}" />

                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,5,0,0">
                                            <RadioButton Content="Zoom"
                                                         GroupName="ZoomOptions"
                                                         IsChecked="{Binding ZoomType,
                                                                 Converter={StaticResource EnumToBoolConverter},
                                                                 ConverterParameter=Zoom}" />

                                            <TextBox Width="50"
                                                     Margin="10,0,5,0"
                                                     Text="{Binding ZoomPercentage}"
                                                     IsEnabled="{Binding IsZoomPercent}" />

                                            <TextBlock Text="% size"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>

                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Paper Placement"
                                      Width="248">
                                <StackPanel Margin="5">

                                    <!-- Option 1 -->
                                    <RadioButton Content="Center on Paper"
                                                 GroupName="PaperPlacement"
                                                 IsChecked="{Binding PaperPlacement,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=Center}" />
                                    <RadioButton GroupName="PaperPlacement"
                                                 Content="Lower Left"
                                                 IsChecked="{Binding PaperPlacement,
                                                        Converter={StaticResource EnumToBoolConverter},
                                                            ConverterParameter=LowerLeft}"
                                                 HorizontalAlignment="Left"
                                                 Width="81" />

                                    <!-- Option 2 -->
                                    <!--<StackPanel Orientation="Horizontal"
                                                        Margin="0,5,0,0"
                                                        VerticalAlignment="Center">
                                                <RadioButton GroupName="PaperPlacement"
                                                             IsChecked="{Binding PaperPlacement,
                                                             Converter={StaticResource EnumToBoolConverter},
                                                             ConverterParameter=LowerLeft}"
                                                             VerticalAlignment="Center"
                                                             Width="81">
                                                    <TextBlock Text="Margin"
                                                               TextWrapping="Wrap" />
                                                </RadioButton>
                                                <TextBox Width="53"
                                                         Text="{Binding OriginOffsetX}"
                                                         IsEnabled="{Binding IsCustomOffset}" />
                                                <TextBlock Text="X"
                                                           Margin="5,0" />

                                                <TextBox Width="53"
                                                         Text="{Binding OriginOffsetY}"
                                                         IsEnabled="{Binding IsCustomOffset}" />
                                                <TextBlock Text="Y"
                                                           Margin="5,0" />
                                            </StackPanel>-->

                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal">
                            <GroupBox Header="Orientation">
                                <StackPanel>
                                    <RadioButton Content="Automatic"
                                                 IsChecked="{Binding PaperOrientation,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=Auto}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Margin="10,5,10,5" />
                                    <RadioButton Content="Portrait"
                                                 IsChecked="{Binding PaperOrientation,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=Portrait}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Margin="10,5,10,5" />
                                    <RadioButton Content="Landscape"
                                                 IsChecked="{Binding PaperOrientation,
                                                         Converter={StaticResource EnumToBoolConverter},
                                                         ConverterParameter=Landscape}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Margin="10,5,10,5" />
                                </StackPanel>

                            </GroupBox>
                            <GroupBox Header="Appearance"
                                      Width="230">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*" />
                                        <RowDefinition Height="1*" />
                                        <RowDefinition Height="1*" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Raster Quality:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="Colors:"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               HorizontalAlignment="Right" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Text="Export Quality (DPI):"
                                               TextWrapping="Wrap"
                                               Width="91"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               HorizontalAlignment="Right"
                                               TextAlignment="Right" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              Width="80"
                                              ItemsSource="{Binding RasterQualityOptions}"
                                              SelectedItem="{Binding SelectedRasterQuality}"
                                              Margin="0,5,0,5"
                                              Height="23" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              Width="80"
                                              ItemsSource="{Binding ColorDepthOptions}"
                                              SelectedItem="{Binding SelectedColorDepth}"
                                              Margin="0,5,0,5"
                                              Height="23" />
                                    <ComboBox Grid.Row="2"
                                              Grid.Column="1"
                                              Width="80"
                                              ItemsSource="{Binding ExportQualityOptions}"
                                              SelectedItem="{Binding SelectedExportQuality}"
                                              Margin="0,5,0,5"
                                              Height="23" />

                                </Grid>
                            </GroupBox>
                            <GroupBox Header="Graphic Processing"
                                      Width="148">
                                <StackPanel>
                                    <RadioButton Content="Vector"
                                                 IsChecked="{Binding IsVectorProcessing}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Margin="10,5,10,5" />
                                    <RadioButton Content="Raster"
                                                 IsChecked="{Binding IsRasterProcessing}"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Margin="10,5,10,5" />

                                </StackPanel>
                            </GroupBox>
                        </StackPanel>

                    </Grid>
                    <GroupBox Header="Options"
                              Grid.Column="1">
                        <StackPanel>
                            <CheckBox Content="View Links in blue"
                                      IsChecked="{Binding ViewLinksInBlue}"
                                      Margin="8,5,0,5" />
                            <CheckBox Content="Hide ref/work planes"
                                      IsChecked="{Binding HideReferencePlanes}"
                                      Margin="8,5,0,5" />
                            <CheckBox Content="Hide unreferenced view tags"
                                      IsChecked="{Binding HideUnreferencedViewTags}"
                                      Margin="8,5,0,5" />
                            <CheckBox IsChecked="{Binding MaskCoincidentLines}"
                                      Margin="8,5,0,5">
                                <TextBlock Text="Region edges mask coincident lines"
                                           TextWrapping="Wrap" />
                            </CheckBox>
                            <CheckBox Content="Hide scope boxes"
                                      IsChecked="{Binding HideScopeBoxes}"
                                      Margin="8,5,0,5" />
                            <CheckBox Content="Hide crop bourdaries"
                                      IsChecked="{Binding HideCropBoundaries}"
                                      Margin="8,5,0,5" />
                            <CheckBox Content="Replace halftones with thin lines"
                                      IsChecked="{Binding ReplaceHalftoneLines}"
                                      Margin="8,5,0,5" />
                        </StackPanel>
                    </GroupBox>

                </Grid>

            </StackPanel>

        </StackPanel>

    </Grid>
</UserControl>
