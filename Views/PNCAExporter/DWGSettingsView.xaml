<UserControl x:Class="PNCA_BIM_Suite_Library.Views.PNCAExporter.DWGSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views.PNCAExporter"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PNCA_BIM_Suite_Library;component/Views/ButtonStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="White">
        <StackPanel>
            <GroupBox Header="DWG Settings"
                      Style="{StaticResource BoldGroupBoxHeaderStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DWG Export Setup:"
                                   FontWeight="DemiBold"
                                   Margin="10,10,5,0"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center" />
                        <ComboBox Width="200"
                                  Margin="5,10,0,0"
                                  ItemsSource="{Binding DWGExportSetups}" 
                                  SelectedItem="{Binding SelectedDWGExportSetup}"
                                  DisplayMemberPath="Name"/>

                    </StackPanel>
                    <CheckBox Content="Export views on sheets and links as external references"
                              Margin="10,10,0,10"
                              IsChecked="{Binding IsExternalReferencesChecked}"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

    </Grid>
</UserControl>
