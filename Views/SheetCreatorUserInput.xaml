<Window x:Class="PNCA_BIM_Suite_Library.Views.SheetCreatorUserInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views"
             WindowStyle="None"
             AllowsTransparency="True"
             
             Height="450"
             Width="400"
             WindowStartupLocation="CenterScreen">
    <Border Background="White" BorderBrush="#3A3A3A" 
        BorderThickness="1" VerticalAlignment="Center" Padding="0,0,0,0" Height="450">
        <DockPanel LastChildFill="True">
            <Border Background="#2B2B2B" Height="32" DockPanel.Dock="Top" 
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <local:PNCATitleBar
                Title="SheetGEN : User Input"
                                    TitleIcon="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/SheetCreatorUserInput-Titlebar.ico"/>
            </Border>
            <Grid Margin="10">
                <StackPanel>
                    <GroupBox Header="Number of Sheets:" Margin="0,0,0,10" FontSize="14">
                        <TextBox x:Name="NumberOfSheetsTextBox" Margin="0,5,0,10" FontSize="14" Width="300" Height="25"/>
                    </GroupBox>

                    <GroupBox Header="Sheet Name:" Margin="0,0,0,10" FontSize="14">
                        <TextBox x:Name="SheetNameTextBox" Margin="0,5,0,10" FontSize="14" Width="300" Height="25"/>
                    </GroupBox>


                    <GroupBox Header="Start Sheet Number:" Margin="0,0,0,10" FontSize="14">
                        <TextBox x:Name="SheetNumberTextBox" Margin="0,5,0,10" FontSize="14" Width="300" Height="25"/>
                    </GroupBox>

                    <GroupBox Header="Title Block:" Margin="0,0,0,10" FontSize="14">
                        <ComboBox x:Name="UserTitleBlockDropDown" Width="300" Height="25" Margin="0,5,0,10"/>
                    </GroupBox>

                    <StackPanel Orientation="Horizontal" Margin="10,20,0,10">
                        <Button Content="Create" Width="100" 
                                Height="30" Click="UserCreateButton_Click"
                                FontSize="14"
                                Foreground="White" Background="#FF4F4F50"/>
                        <Button Content="Cancel" Width="100" 
                                Height="30" Margin="10,0,0,0" 
                                Click="UserCancelButton_Click"
                                FontSize="14"
                                Foreground="White" Background="#FF4F4F50"/>
                    </StackPanel>

                    <Image Source="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/PNC Logo.png"
                       Height="50"
                       Width="50"
                       HorizontalAlignment="Right"
                       Margin="0,-50,5,0"
                       VerticalAlignment="Top"/>
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>
