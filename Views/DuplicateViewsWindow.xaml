<Window x:Class="PNCA_BIM_Suite_Library.Views.DuplicateViewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PNCA_BIM_Suite_Library.Views"
        Title="View Duplicator"
        Height="680"
        Width="650"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Border Background="White"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            VerticalAlignment="Center"
            Padding="0,0,0,0"
            Height="680">
        <DockPanel LastChildFill="True">
            <Border Background="#2B2B2B"
                    Height="32"
                    DockPanel.Dock="Top"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <local:PNCATitleBar Title="Duplicate Views"
                                    TitleIcon="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/ViewDuplicator-Titlebar.tiff"
                                    Loaded="TitleBar_Loaded" />

            </Border>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="552" />
                    <RowDefinition Height="48" />

                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="2*" />

                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Margin="0,12,10,34">
                    <GroupBox Header="Duplication Options"
                              Padding="15">
                        <StackPanel>
                            <RadioButton Name="rbDuplicate"
                                         Content="Duplicate"
                                         IsChecked="True"
                                         Margin="0,0,0,5" />
                            <RadioButton Name="rbDuplicateWithDetailing"
                                         Content="Duplicate with Detailing"
                                         Margin="0,0,0,5" />
                            <RadioButton Name="rbDuplicateAsDependent"
                                         Content="Duplicate As Dependent"
                                         Margin="0,0,0,5" />

                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Duplicate Views Count"
                              Padding="10">
                        <StackPanel>

                            <TextBox Name="DuplicateViewCount"
                                     Margin="0,0,0,5"
                                     Height="20"
                                     Width="200"
                                     VerticalAlignment="Center" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="View Types"
                              Margin="0,10,0,0"
                              Height="310">
                        <Border BorderBrush="Gray">
                            <ListBox Name="lstViewTypes"
                                     Background="White" />
                        </Border>
                    </GroupBox>

                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="0,0,10,34">

                    <GroupBox Header="Views"
                              Margin="0,10,0,0"
                              Height="500">
                        <Border BorderBrush="Gray">
                            <ListBox Name="lstViews"
                                     Background="White" />
                        </Border>
                    </GroupBox>

                </StackPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,-1"
                            Width="180">
                    <Button Name="btnCreate"
                            Content="Create"
                            Width="80"
                            Height="30"
                            Margin="0,0,10,0"
                            Click="btnCreate_Click"
                            FontSize="14"
                            Foreground="White"
                            Background="#FF4F4F50" />
                    <Button Name="btnCancel"
                            Content="Cancel"
                            Width="80"
                            Height="30"
                            Margin="0,0,10,0"
                            Click="btnCancel_Click"
                            FontSize="14"
                            Foreground="White"
                            Background="#FF4F4F50" />
                </StackPanel>

                <Image Grid.Row="1"
                       Grid.Column="1"
                       Source="pack://application:,,,/PNCA_BIM_Suite_Library;component/Resources/PNC Logo.png"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Width="100"
                       Height="50"
                       Margin="0,10,20,0"
                       Stretch="Uniform" />
            </Grid>
        </DockPanel>
    </Border>
</Window>